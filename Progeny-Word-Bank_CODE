if __name__ == "__main__":
    op = DynamicStylisticOperator()
    print("Extensive Word Bank Dynamic Stylistic Operator Initialized\n")
    
    for i in range(8):
        state = op.next_state()
        para = op.generate_paragraph(3 if i % 3 == 0 else 1)
        print(f"n={state['n']:2d} | C={state['C']:9} | D={state['D']:.2f} | "
              f"M={state['M']} | Peak={state['surmounted']:.2f}")
        print(para)
        print("-" * 90)
    
    op.summary()
